-- Script for : https://www.roblox.com/fr/games/126884695634066/Grow-a-Garden
-- Browse seeds by rarity, select the ones you want, then enable Auto-Buy in the Auto tab.
-- The script will roll the seed machine and purchase any matching seed automatically.
-- Enable Auto-Collect to sell your crates every 2 minutes.

local VoidUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/femmehomme90-web/VoidUI/refs/heads/main/voidUI.lua"))()
VoidUI:SetScriptName("Build-A-Ring-Farm script")
print("V3")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- ════════════════════════════════════════════════════════
--  DONNÉES
-- ════════════════════════════════════════════════════════

-- 1. Plot du joueur
local Plots = workspace.Map.Plots
local myPlot = nil

for i = 1, 6 do
    local plot = Plots:FindFirstChild("Plot" .. i)
    if plot then
        local attachment = plot:FindFirstChild("HomeLabelAttachment")
        if attachment and #attachment:GetChildren() > 0 then
            myPlot = plot
            break
        end
    end
end

if not myPlot then
    VoidUI:Notify({ Title = "Erreur", Message = "Plot introuvable !", Type = "error", Duration = 4 })
    return
end

-- 2. Stands du plot
local seedRoller = myPlot:FindFirstChild("SeedRoller")
local stands = {}

for i = 1, 6 do
    local stand = seedRoller:FindFirstChild("Stand" .. i)
    if stand then
        stands[i] = { index = i, position = stand:GetPivot().Position }
    end
end

-- 3. Scan workspace -> cherche BuySeed en descendant
local function getWorldSeeds()
    local seeds = {}
    for _, model in ipairs(workspace:GetChildren()) do
        if model:IsA("Model") then
            local buySeed = model:FindFirstChild("BuySeed", true)
            if buySeed then
                local seedPos = model:GetPivot().Position
                local bestStand, bestDist = nil, math.huge
                for _, stand in pairs(stands) do
                    local dx = seedPos.X - stand.position.X
                    local dz = seedPos.Z - stand.position.Z
                    local dist = math.sqrt(dx*dx + dz*dz)
                    if dist < bestDist then bestDist = dist; bestStand = stand end
                end
                if bestStand and bestDist < 15 then
                    seeds[model.Name] = bestStand.index
                end
            end
        end
    end
    return seeds
end

-- 4. Collecte tous les FarmPlot (rez + étages)
local function getFarmPlots()
    local farmPlots = {}

    local fp = myPlot:FindFirstChild("FarmPlot")
    if fp then table.insert(farmPlots, fp) end

    local second = myPlot:FindFirstChild("SecondFloor")
    if second then
        local fp2 = second:FindFirstChild("FarmPlot")
        if fp2 then table.insert(farmPlots, fp2) end
    end

    local third = myPlot:FindFirstChild("ThirdFloor")
    if third then
        local fp3 = third:FindFirstChild("FarmPlot")
        if fp3 then table.insert(farmPlots, fp3) end
    end

    return farmPlots
end

-- 5. Graines depuis l'UI du jeu
local scrollFrame = game:GetService("Players").LocalPlayer.PlayerGui.MainUI.Menus.IndexFrame.Main.ScrollingFrame
local allSeeds = {}

local rarityOrder = {
    "Common", "Uncommon", "Rare", "Epic", "Legendary",
    "Divine", "Prismatic", "Secret", "Exotic", "Transcended"
}

for _, child in ipairs(scrollFrame:GetChildren()) do
    if child:IsA("Frame") then
        local icon     = child:FindFirstChild("Icon")
        local rarity   = child:FindFirstChild("RarityName")
        local seedName = child:FindFirstChild("SeedName")
        local name     = (seedName and seedName.Text ~= "???" and seedName.Text) or child.Name
        table.insert(allSeeds, {
            Name   = name,
            Key    = child.Name,
            Icon   = icon   and icon.Image or "",
            Rarity = rarity and rarity.Text or "Common",
        })
    end
end

-- Groupe par rareté
local seedsByRarity = {}
for _, r in ipairs(rarityOrder) do
    seedsByRarity[r] = {}
end

for _, s in ipairs(allSeeds) do
    if seedsByRarity[s.Rarity] then
        table.insert(seedsByRarity[s.Rarity], s)
    else
        table.insert(seedsByRarity["Common"], s)
    end
end

-- ════════════════════════════════════════════════════════
--  UI
-- ════════════════════════════════════════════════════════
local Win = VoidUI:CreateWindow({
    Title       = "Grow a Garden",
    Size        = UDim2.new(0, 650, 0, 500),
    TabPosition = "side",
})

local selectedSeeds = {}
local buying        = false
local stopBuying    = false

-- Un tab par rareté
for _, rarity in ipairs(rarityOrder) do
    local seeds = seedsByRarity[rarity]
    if #seeds == 0 then continue end

    local Tab = Win:AddTab(rarity)
    Tab:AddLabel(rarity .. " — " .. #seeds .. " graine(s)")

    local cardItems = {}
    for _, s in ipairs(seeds) do
        table.insert(cardItems, { Name = s.Name, Icon = s.Icon })
    end

    Tab:AddCardGrid({
        Items    = cardItems,
        Columns  = 3,
        Callback = function(sel)
            for _, s in ipairs(seeds) do
                selectedSeeds[s.Name] = nil
            end
            for k, v in pairs(sel) do
                selectedSeeds[k] = v
            end
        end,
    })
end

-- ════════════════════════════════════════════════════════
--  TAB AUTO
-- ════════════════════════════════════════════════════════
local TabCtrl = Win:AddTab("Auto")

-- ── Auto-Buy ──
TabCtrl:AddLabel("Auto-Buy")

TabCtrl:AddToggle({
    Label   = "Activer Auto-Buy",
    Default = false,
    Callback = function(state)
        if state then
            if buying then return end
            buying     = true
            stopBuying = false

            task.spawn(function()
                while not stopBuying do
                    if next(selectedSeeds) == nil then
                        task.wait(1)
                        continue
                    end

                    ReplicatedStorage.Remotes.RollSeeds:FireServer()
                    task.wait(3)

                    local worldSeeds = getWorldSeeds()

                    for seedName, standIdx in pairs(worldSeeds) do
                        if stopBuying then break end
                        if selectedSeeds[seedName] then
                            ReplicatedStorage.Remotes.BuySeed:FireServer(standIdx)
                            VoidUI:Notify({
                                Title    = "Acheté !",
                                Message  = seedName .. " -> Stand" .. standIdx,
                                Type     = "success",
                                Duration = 3,
                            })
                            task.wait(0.5)
                        end
                    end
                end

                buying = false
            end)
        else
            stopBuying = true
            VoidUI:Notify({
                Title    = "Stoppé",
                Message  = "Auto-buy arrêté.",
                Type     = "warning",
                Duration = 3,
            })
        end
    end,
})

-- ── Auto-Collect ──
TabCtrl:AddLabel("Auto-Collect")

local collecting     = false
local stopCollecting = false

TabCtrl:AddToggle({
    Label   = "Activer Auto-Collect",
    Default = false,
    Callback = function(state)
        if state then
            if collecting then return end
            collecting     = true
            stopCollecting = false

            task.spawn(function()
                while not stopCollecting do
                    ReplicatedStorage.Remotes.SellCrates:FireServer()
                    VoidUI:Notify({
                        Title    = "Collect !",
                        Message  = "Caisses vendues.",
                        Type     = "success",
                        Duration = 2,
                    })
                    task.wait(120)
                end
                collecting = false
            end)
        else
            stopCollecting = true
            VoidUI:Notify({
                Title    = "Stoppé",
                Message  = "Auto-collect arrêté.",
                Type     = "warning",
                Duration = 3,
            })
        end
    end,
})

-- ── Auto-Upgrade ──
TabCtrl:AddLabel("Auto-Upgrade Plants")

local targetLevel = 10
TabCtrl:AddSlider({
    Label    = "Niveau cible",
    Min      = 1, Max = 75, Default = 10,
    Callback = function(v) targetLevel = v end,
})

TabCtrl:AddButton({
    Label  = "▶ Upgrade toutes les plantes",
    Colors = { Color3.fromRGB(255, 140, 40), Color3.fromRGB(255, 200, 40) },
    Callback = function()
        local farmPlots = getFarmPlots()
        if #farmPlots == 0 then
            VoidUI:Notify({ Title = "Erreur", Message = "FarmPlot introuvable !", Type = "error", Duration = 3 })
            return
        end

        task.spawn(function()
            local upgraded = 0
            for _, farmPlot in ipairs(farmPlots) do
                for _, plant in ipairs(farmPlot:GetChildren()) do
                    local dirt = plant:FindFirstChild("Dirt")
                    if dirt and dirt:GetAttribute("PlantLevel") ~= nil then
                        local currentLvl = dirt:GetAttribute("PlantLevel") or 0
                        while currentLvl < targetLevel do
                            ReplicatedStorage.Remotes.UpgradePlant:InvokeServer(dirt)
                            task.wait(0.1)
                            currentLvl = dirt:GetAttribute("PlantLevel") or 0
                        end
                        upgraded = upgraded + 1
                    end
                end
            end

            VoidUI:Notify({
                Title    = "Upgrade terminé !",
                Message  = upgraded .. " plante(s) au niveau " .. targetLevel,
                Type     = "success",
                Duration = 4,
            })
        end)
    end,
})

-- ════════════════════════════════════════════════════════
--  TAB INFO
-- ════════════════════════════════════════════════════════
local TabInfo = Win:AddTab("Info")
TabInfo:AddLabel("Plot détecté")
TabInfo:AddButton({ Label = myPlot.Name, Callback = function() end })

TabInfo:AddLabel("Stands au démarrage")
local initSeeds = getWorldSeeds()
for name, idx in pairs(initSeeds) do
    TabInfo:AddLabel(name .. "  ->  Stand" .. idx)
end
