    return
end

VoidUI:Notify({ Title = "Pickaxe Tycoon", Message = "Plot trouvé : " .. myPlot.Name, Type = "success", Duration = 3 })

-- Parse un montant en M/K/B vers un nombre
local function parseMoney(str)
    str = str:gsub(",", ".")
    local num, suffix = str:match("([%d%.]+)([MKB]?)")
    num = tonumber(num)
    if not num then return 0 end
    if suffix == "M" then return num * 1000000
    elseif suffix == "K" then return num * 1000
    elseif suffix == "B" then return num * 1000000000
    end
    return num
end

-- Références
local multText  = workspace.OreMultPart.BillboardGui.Frame.MultText
local priceText = workspace.Plots:FindFirstChild(myPlot.Name).Sell.UpgradeButton.BillboardGui.Frame.PriceText
local buy100PriceText = workspace.Plots:FindFirstChild(myPlot.Name).Buttons.ButtonBuy100.BillboardGui.Frame.PriceText
local cashText  = localPlayer.PlayerGui:WaitForChild("CurrencyGui").Frame.CashText

-- Config
local minMult      = 1.4
local upgradeWait  = 60
local sellActive         = false
local collectActive      = false
local upgradeActive      = false
local collectMoneyActive = false
