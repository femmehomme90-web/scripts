-- ── Fonctions ──
local function autoSell()
    local char = localPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local button = workspace.Plots:FindFirstChild(myPlot.Name).Sell.DepositButton.Button
    firetouchinterest(hrp, button, 0)
    task.wait(0.1)
    firetouchinterest(hrp, button, 1)
end

local function autoCollect()
    local lootFolder = myPlot:FindFirstChild("LootSpawned")
    if not lootFolder then return end

    local levels = {}
    for _, loot in ipairs(lootFolder:GetChildren()) do
        local level = tonumber(loot.Name:match("%d+"))
        if level then table.insert(levels, level) end
    end

    if #levels > 0 then
        ReplicatedStorage.RemoteEvents.LootPickup:FireServer(levels)
        VoidUI:Notify({ Title = "Auto Collect", Message = #levels .. " loots collectés", Type = "info", Duration = 2 })
    end
end

local function autoUpgrade()
    local char = localPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    local price = parseMoney(priceText.Text)
    local cash  = parseMoney(cashText.Text)

    if cash >= price then
        local button = workspace.Plots:FindFirstChild(myPlot.Name).Sell.UpgradeButton.Button
        firetouchinterest(hrp, button, 0)
        task.wait(0.1)
        firetouchinterest(hrp, button, 1)
        VoidUI:Notify({ Title = "Auto Upgrade", Message = "Upgrade acheté !", Type = "success", Duration = 2 })
        return true
    end
    return false
end

