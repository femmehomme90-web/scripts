local VoidUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/femmehomme90-web/VoidUI/refs/heads/main/voidUI.lua"))()

-- ════════════════════════════════════════════════════════
--  DONNÉES
-- ════════════════════════════════════════════════════════

-- 1. Plot du joueur
local Plots = workspace.Map.Plots
local myPlot = nil

for i = 1, 6 do
    local plot = Plots:FindFirstChild("Plot" .. i)
    if plot then
        local attachment = plot:FindFirstChild("HomeLabelAttachment")
        if attachment and #attachment:GetChildren() > 0 then
            myPlot = plot
            break
        end
    end
end

if not myPlot then
    VoidUI:Notify({ Title = "Erreur", Message = "Plot introuvable !", Type = "error", Duration = 4 })
    return
end

-- 2. Stands du plot
local seedRoller = myPlot:FindFirstChild("SeedRoller")
local stands = {}

for i = 1, 6 do
    local stand = seedRoller:FindFirstChild("Stand" .. i)
    if stand then
        stands[i] = { index = i, position = stand:GetPivot().Position }
    end
end

-- 3. Scan workspace -> lie graines aux stands
local function getWorldSeeds()
    local seeds = {}
    for _, model in ipairs(workspace:GetChildren()) do
        if model:IsA("Model") and model:FindFirstChildOfClass("UnionOperation") then
            local seedPos = model:GetPivot().Position
            local bestStand, bestDist = nil, math.huge
            for _, stand in pairs(stands) do
                local dx = seedPos.X - stand.position.X
                local dz = seedPos.Z - stand.position.Z
                local dist = math.sqrt(dx*dx + dz*dz)
                if dist < bestDist then bestDist = dist; bestStand = stand end
            end
            if bestStand and bestDist < 15 then
                seeds[model.Name] = bestStand.index
            end
        end
    end
    return seeds
end

-- 4. Graines depuis l'UI du jeu
local scrollFrame = game:GetService("Players").LocalPlayer.PlayerGui.MainUI.Menus.IndexFrame.Main.ScrollingFrame
local allSeeds = {}

for _, child in ipairs(scrollFrame:GetChildren()) do
    if child:IsA("Frame") or child:IsA("ImageButton") or child:IsA("ImageLabel") then
        local icon     = child:FindFirstChild("Icon")
        local rarity   = child:FindFirstChild("RarityName")
        local seedName = child:FindFirstChild("SeedName")
        local name     = (seedName and seedName.Text ~= "???" and seedName.Text) or child.Name
        table.insert(allSeeds, {
            Name   = name,
            Key    = child.Name,
            Icon   = icon and icon.Image or "",
            Rarity = rarity and rarity.Text or "",
        })
    end
end

-- ════════════════════════════════════════════════════════
--  UI
-- ════════════════════════════════════════════════════════
local Win = VoidUI:CreateWindow({
    Title = "Grow a Garden",
    Size  = UDim2.new(0, 600, 0, 480),
})

local TabSeeds   = Win:AddTab("Seeds")
local TabFarm    = Win:AddTab("Farm")
local TabInfo    = Win:AddTab("Info")

-- ════════════════════════════════════════════════════════
--  TAB SEEDS — autobuy / autoroll
-- ════════════════════════════════════════════════════════
local cardItems = {}
for _, s in ipairs(allSeeds) do
    table.insert(cardItems, { Name = s.Name, Icon = s.Icon })
end

TabSeeds:AddLabel("Sélectionne les graines à acheter")

local selectedSeeds = {}
TabSeeds:AddCardGrid({
    Items    = cardItems,
    Columns  = 4,
    Callback = function(sel) selectedSeeds = sel end,
})

local delay = 1
TabSeeds:AddSlider({
    Label    = "Délai entre achats",
    Min      = 0, Max = 5, Default = 1,
    Suffix   = "s",
    Callback = function(v) delay = v end,
})

local buying        = false
local stopBuying    = false

TabSeeds:AddButton({
    Label  = "▶ Start Auto-Buy",
    Colors = { Color3.fromRGB(130, 80, 255), Color3.fromRGB(220, 80, 160) },
    Callback = function()
        if buying then return end
        buying     = true
        stopBuying = false

        task.spawn(function()
            while not stopBuying do
                for seedName, _ in pairs(selectedSeeds) do
                    if stopBuying then break end

                    local key = nil
                    for _, s in ipairs(allSeeds) do
                        if s.Name == seedName then key = s.Key; break end
                    end
                    if not key then continue end

                    local standIdx = nil
                    local rolls    = 0
                    repeat
                        if stopBuying then break end
                        local worldSeeds = getWorldSeeds()
                        standIdx = worldSeeds[key]
                        if not standIdx then
                            game:GetService("ReplicatedStorage").Remotes.RollSeeds:FireServer()
                            rolls = rolls + 1
                            VoidUI:Notify({
                                Title    = "Roll #" .. rolls,
                                Message  = "Recherche : " .. seedName,
                                Type     = "info",
                                Duration = 1,
                            })
                            task.wait(1.5)
                        end
                    until standIdx ~= nil or stopBuying

                    if stopBuying then break end

                    game:GetService("ReplicatedStorage").Remotes.BuySeed:FireServer(standIdx)
                    VoidUI:Notify({
                        Title    = "Acheté !",
                        Message  = seedName .. " après " .. rolls .. " roll(s) (Stand " .. standIdx .. ")",
                        Type     = "success",
                        Duration = 3,
                    })
                    task.wait(delay)
                end

                task.wait(2)
            end

            buying = false
            VoidUI:Notify({
                Title    = "Stoppé",
                Message  = "Auto-buy arrêté.",
                Type     = "warning",
                Duration = 3,
            })
        end)
    end,
})

TabSeeds:AddButton({
    Label    = "■ Stop Auto-Buy",
    Callback = function()
        if not buying then return end
        stopBuying = true
    end,
})

-- ════════════════════════════════════════════════════════
--  TAB FARM — autocollect
-- ════════════════════════════════════════════════════════
local collecting     = false
local stopCollecting = false

TabFarm:AddLabel("Auto Collect")

TabFarm:AddButton({
    Label  = "▶ Start Auto-Collect",
    Colors = { Color3.fromRGB(55, 210, 120), Color3.fromRGB(30, 160, 90) },
    Callback = function()
        if collecting then return end
        collecting     = true
        stopCollecting = false

        task.spawn(function()
            while not stopCollecting do
                game:GetService("ReplicatedStorage").Remotes.SellCrates:FireServer()
                VoidUI:Notify({
                    Title    = "Collect !",
                    Message  = "Caisses vendues.",
                    Type     = "success",
                    Duration = 2,
                })
                task.wait(120)
            end

            collecting = false
            VoidUI:Notify({
                Title    = "Stoppé",
                Message  = "Auto-collect arrêté.",
                Type     = "warning",
                Duration = 3,
            })
        end)
    end,
})

TabFarm:AddButton({
    Label    = "■ Stop Auto-Collect",
    Callback = function()
        if not collecting then return end
        stopCollecting = true
    end,
})

