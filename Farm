--  UI
-- ════════════════════════════════════════════════════════
local Win = VoidUI:CreateWindow({
    Title = "Grow a Garden",
    Size  = UDim2.new(0, 600, 0, 480),
})

local Tab = Win:AddTab("Seeds")
local TabInfo = Win:AddTab("Info")

-- Convertit allSeeds en items pour CardGrid
local cardItems = {}
for _, s in ipairs(allSeeds) do
    table.insert(cardItems, { Name = s.Name, Icon = s.Icon })
end

Tab:AddLabel("Sélectionne les graines à acheter")

local selectedSeeds = {}
local cardGrid = Tab:AddCardGrid({
    Items    = cardItems,
    Columns  = 4,
    Callback = function(sel) selectedSeeds = sel end,
})

-- Slider délai entre achats
local delay = 1
local delaySlider = Tab:AddSlider({
    Label   = "Délai entre achats",
    Min     = 0, Max = 5, Default = 1,
    Suffix  = "s",
    Callback = function(v) delay = v end,
})

-- Bouton acheter
local buying = false
Tab:AddButton({
    Label  = "Acheter les graines sélectionnées",
    Colors = { Color3.fromRGB(130, 80, 255), Color3.fromRGB(220, 80, 160) },
    Callback = function()
        if buying then return end
        buying = true

        local worldSeeds = getWorldSeeds()

        local bought = 0
        for seedName, _ in pairs(selectedSeeds) do
            -- Cherche le Key correspondant dans allSeeds
            local standIdx = nil
            for _, s in ipairs(allSeeds) do
                if s.Name == seedName then
                    standIdx = worldSeeds[s.Key]
                    break
                end
            end

            if standIdx then
                game:GetService("ReplicatedStorage").Remotes.BuySeed:FireServer(standIdx)
                bought = bought + 1
                VoidUI:Notify({
                    Title   = "Acheté !",
                    Message = seedName .. " (Stand " .. standIdx .. ")",
                    Type    = "success",
                    Duration = 2,
                })
                task.wait(delay)
            else
                VoidUI:Notify({
                    Title   = "Introuvable",
                    Message = seedName .. " n'est pas disponible en ce moment",
                    Type    = "warning",
                    Duration = 2,
                })
            end
        end

        VoidUI:Notify({
            Title   = "Terminé",
            Message = bought .. " graine(s) achetée(s)",
            Type    = "info",
            Duration = 3,
        })
        buying = false
    end,
})

-- Tab Info
TabInfo:AddLabel("Plot")
TabInfo:AddButton({
    Label    = myPlot.Name,
    Callback = function() end,
})

TabInfo:AddLabel("Stands actifs")
local worldSeeds = getWorldSeeds()
for name, idx in pairs(worldSeeds) do
    TabInfo:AddLabel(name .. " -> Stand" .. idx)
end
